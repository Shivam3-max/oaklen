# Copy this file to .env (local) — never commit the real .env.
# Vercel: add the same DATABASE_URL under Project Settings -> Environment Variables.

# MySQL connection string. Most hosts want SSL — append the flag your provider docs give you.
# Example shapes:
#   mysql://user:password@host:3306/oaklen
#   mysql://user:password@host:3306/oaklen?sslaccept=strict   (PlanetScale)
#   mysql://user:password@host:3306/oaklen?ssl={"rejectUnauthorized":true}
DATABASE_URL="mysql://user:password@host:3306/oaklen"

# Admin panel passcode (change this before going live). Defaults to oaklen2026 if unset.
OAKLEN_ADMIN_KEY="oaklen2026"

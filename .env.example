# Copy this file to .env (local) — never commit the real .env.
# On Hostinger, set each of these in your Node.js app's Environment Variables.

# ---- Database (REQUIRED to save products, images and bookings) ----
# MySQL connection string from Hostinger (hPanel -> Databases -> MySQL).
#   mysql://user:password@host:3306/dbname
DATABASE_URL=""

# ---- Admin panel (REQUIRED — set a strong passcode) ----
# The passcode for /admin. Defaults to "oaklen2026" if unset — change it.
OAKLEN_ADMIN_KEY=""

# ---- Email (optional — booking + enquiry notifications) ----
# From resend.com. EMAIL_FROM must be a verified sender on your domain.
RESEND_API_KEY=""
EMAIL_FROM="Oaklen <care@oaklen.in>"
# Where new-booking and enquiry alerts are sent (defaults to the brand email).
EMAIL_STAFF=""

# ---- Analytics (optional) ----
# Google Analytics 4 measurement id, e.g. G-XXXXXXX.
NEXT_PUBLIC_GA_ID=""

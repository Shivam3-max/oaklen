# Copy this file to .env (local) — never commit the real .env.
# In Vercel, add each of these under Project Settings -> Environment Variables.
# EVERYTHING is optional: with nothing set, the site runs in demo mode
# (in-memory data, no real payments, no emails). Add each key to switch that
# capability on for production.

# ---- Database (persist real orders/products) ----
# MySQL connection string. Append the SSL flag your host documents.
#   mysql://user:password@host:3306/oaklen
DATABASE_URL=""

# ---- Admin panel ----
# Passcode for /admin. Defaults to "oaklen2026" if unset — change before launch.
OAKLEN_ADMIN_KEY=""

# ---- Payments (Razorpay) ----
# From Razorpay Dashboard -> Settings -> API Keys. Use test keys first.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# From Razorpay Dashboard -> Settings -> Webhooks (set the URL to
# https://your-domain/api/razorpay/webhook and copy the secret here).
RAZORPAY_WEBHOOK_SECRET=""

# ---- Email (Resend) ----
# From resend.com. EMAIL_FROM must be a verified sender on your domain.
RESEND_API_KEY=""
EMAIL_FROM="Oaklen <care@oaklen.in>"
# Where new-order and enquiry alerts are sent (defaults to the brand email).
EMAIL_STAFF=""

# ---- Analytics (optional) ----
# Google Analytics 4 measurement id, e.g. G-XXXXXXX.
NEXT_PUBLIC_GA_ID=""

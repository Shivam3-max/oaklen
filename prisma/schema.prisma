generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  living
  sleep
  dine
  accents
}

enum ProductStyle {
  modern
  classic
}

enum OrderStatus {
  new
  in_atelier
  delivered
}

enum EnquiryKind {
  consultation
  swatch_kit
  reward
}

enum EnquiryStatus {
  new
  contacted
  closed
}

model Product {
  slug       String          @id
  name       String
  line       String
  category   ProductCategory
  type       String
  style      ProductStyle
  silhouette String
  price      Int
  dims       String
  wood       String
  fabrics    Json
  leadDays   Int
  story      String          @db.Text
  plate      Int
  signature  Boolean         @default(false)
  active     Boolean         @default(true)
  images     Json
  createdAt  DateTime        @default(now())

  @@index([category])
}

model SiteImage {
  key       String   @id
  url       String   @db.LongText
  updatedAt DateTime @updatedAt
}

model Order {
  id          String      @id
  subtotal    Int
  custName    String
  custPhone   String
  custEmail   String
  custAddress String      @db.Text
  custPin     String
  note        String?     @db.Text
  status      OrderStatus @default(new)
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@index([custPhone])
}

model OrderItem {
  id      Int     @id @default(autoincrement())
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  slug    String
  name    String
  line    String
  qty     Int
  price   Int
  fabric  String?
}

model Enquiry {
  id        String        @id
  kind      EnquiryKind
  name      String
  phone     String
  note      String?       @db.Text
  status    EnquiryStatus @default(new)
  createdAt DateTime      @default(now())
}

model Subscriber {
  email     String   @id
  createdAt DateTime @default(now())
}
